<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="GroceryListApp.MainPage">
             
    
    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <HorizontalStackLayout Spacing ="15" HorizontalOptions="Center" >
                <Entry x:Name="ItemEntry" Placeholder="Enter item name" WidthRequest="300"/>
                <Button x:Name="AddItemButton" Text="Add Item" Clicked="AddItemButton_Clicked"/>
            </HorizontalStackLayout>
        </VerticalStackLayout>
    </ScrollView>    

</ContentPage>
